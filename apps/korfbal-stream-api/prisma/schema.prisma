generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Sponsor {
  id          Int         @id @default(autoincrement())
  name        String
  type        SponsorType
  logoUrl     String
  websiteUrl  String
  createdAt   DateTime    @default(now())
  categories  String?
  displayName String?
  enabled     Boolean     @default(true)
}

model MatchSchedule {
  id                 Int                   @id @default(autoincrement())
  externalId         String?               @unique
  date               DateTime
  homeTeamName       String
  awayTeamName       String
  accommodationName  String?
  accommodationRoute String?
  attendanceTime     DateTime?
  isPracticeMatch    Boolean               @default(false)
  isHomeMatch        Boolean               @default(false)
  isCompetitiveMatch Boolean               @default(false)
  fieldName          String?
  refereeName        String?
  reserveRefereeName String?
  homeScore          Int?
  awayScore          Int?
  color              String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  description        String?
  isManual           Boolean               @default(false)
  roleAssignments    MatchRoleAssignment[]
  Production         Production?

  @@index([date])
}

/// Catalog of skills (roles) with code and gendered display names
model Skill {
  id          Int                   @id @default(autoincrement())
  code        String                @unique
  nameMale    String
  nameFemale  String
  createdAt   DateTime              @default(now())
  name        String
  type        SkillType             @default(crew)
  assignments MatchRoleAssignment[]
  skills      PersonSkill[]
  Position    Position[]

  @@map("Capability")
}

/// Catalog of production positions (distinct from skills)
model Position {
  id                     Int                         @id @default(autoincrement())
  name                   String                      @unique
  createdAt              DateTime                    @default(now())
  /// Optional link to a skill that is required for this position
  skillId                Int?
  /// Indicates if this is a studio position (true) or production position (false)
  isStudio               Boolean                     @default(false)
  category               PositionCategory            @default(GENERAL)
  sortOrder              Int                         @default(99)
  callSheetItemPositions CallSheetItemPosition[]
  templatePositions      CallSheetTemplatePosition[]
  skill                  Skill?                      @relation(fields: [skillId], references: [id])
  linkedPositions        PositionLink[]              @relation("SourcePosition")
  linkedToPositions      PositionLink[]              @relation("TargetPosition")
  productionEvents       ProductionEventPosition[]
  productionPositions    ProductionPersonPosition[]
  SegmentDefaultPosition SegmentDefaultPosition[]
  segmentAssignments     SegmentRoleAssignment[]
}

/// NIEUW: Koppeling tussen posities voor synchronisatie van de callsheet
model PositionLink {
  id               Int      @id @default(autoincrement())
  sourcePositionId Int
  targetPositionId Int
  sourcePosition   Position @relation("SourcePosition", fields: [sourcePositionId], references: [id], onDelete: Cascade)
  targetPosition   Position @relation("TargetPosition", fields: [targetPositionId], references: [id], onDelete: Cascade)

  @@unique([sourcePositionId, targetPositionId])
}

/// People who can be assigned roles in livestream productions
model Person {
  id                  Int                        @id @default(autoincrement())
  name                String
  gender              Gender
  createdAt           DateTime                   @default(now())
  assignments         MatchRoleAssignment[]
  skills              PersonSkill[]
  productionPresences ProductionPerson[]
  productionPositions ProductionPersonPosition[]
  segmentAssignments  SegmentRoleAssignment[]
}

/// Link table: which skills a person has
model PersonSkill {
  personId  Int
  createdAt DateTime @default(now())
  skillId   Int
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([personId, skillId])
  @@map("PersonCapability")
}

/// Assignment of a person to a role for a specific match
model MatchRoleAssignment {
  id              Int           @id @default(autoincrement())
  matchScheduleId Int
  personId        Int
  createdAt       DateTime      @default(now())
  skillId         Int
  matchSchedule   MatchSchedule @relation(fields: [matchScheduleId], references: [id], onDelete: Cascade)
  person          Person        @relation(fields: [personId], references: [id], onDelete: Cascade)
  skill           Skill         @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([matchScheduleId, skillId, personId])
  @@unique([matchScheduleId, skillId, personId], map: "MatchRoleAssignment_matchScheduleId_capabilityId_personId_key")
  @@index([matchScheduleId])
  @@index([personId])
  @@index([skillId])
}

/// A production instance for a given match
model Production {
  id                  Int                        @id @default(autoincrement())
  matchScheduleId     Int                        @unique
  createdAt           DateTime                   @default(now())
  isActive            Boolean                    @default(false)
  liveTime            DateTime?
  callSheetTemplateId Int?
  callSheets          CallSheet[]
  interviewSubjects   InterviewSubject[]
  callSheetTemplate   CallSheetTemplate?         @relation(fields: [callSheetTemplateId], references: [id])
  matchSchedule       MatchSchedule              @relation(fields: [matchScheduleId], references: [id], onDelete: Cascade)
  events              ProductionEvent[]
  productionPersons   ProductionPerson[]
  productionPositions ProductionPersonPosition[]
  productionReport    ProductionReport?
  segments            ProductionSegment[]
  TitleDefinition     TitleDefinition[]
}

model CallSheetTemplate {
  id          Int                     @id @default(autoincrement())
  name        String                  @unique
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  items       CallSheetTemplateItem[]
  productions Production[]
}

model CallSheetTemplateItem {
  id             String                      @id @default(cuid())
  templateId     Int
  title          String
  note           String?
  durationSec    Int
  orderIndex     Int                         @default(0)
  isInVenue      Boolean                     @default(false)
  isInLivestream Boolean                     @default(true)
  isTimeAnchor   Boolean                     @default(false)
  anchorType     String?
  autoAdvance    Boolean                     @default(false)
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
  template       CallSheetTemplate           @relation(fields: [templateId], references: [id], onDelete: Cascade)
  positions      CallSheetTemplatePosition[]
  parentId       String?
  parent         CallSheetTemplateItem?      @relation("LinkedTemplateItems", fields: [parentId], references: [id], onDelete: SetNull)
  linkedItems    CallSheetTemplateItem[]     @relation("LinkedTemplateItems")

  @@index([templateId])
  @@index([parentId])
}

model CallSheetTemplatePosition {
  templateItemId String
  positionId     Int
  position       Position              @relation(fields: [positionId], references: [id], onDelete: Cascade)
  item           CallSheetTemplateItem @relation(fields: [templateItemId], references: [id], onDelete: Cascade)

  @@id([templateItemId, positionId])
  @@index([positionId])
}

/// People marked as present for a production
model ProductionPerson {
  id           Int        @id @default(autoincrement())
  productionId Int
  personId     Int
  createdAt    DateTime   @default(now())
  person       Person     @relation(fields: [personId], references: [id], onDelete: Cascade)
  production   Production @relation(fields: [productionId], references: [id], onDelete: Cascade)

  @@unique([productionId, personId])
  @@index([productionId])
  @@index([personId])
}

model ProductionPersonPosition {
  id           Int        @id @default(autoincrement())
  productionId Int
  personId     Int
  positionId   Int
  createdAt    DateTime   @default(now())
  person       Person     @relation(fields: [personId], references: [id], onDelete: Cascade)
  position     Position   @relation(fields: [positionId], references: [id], onDelete: Cascade)
  production   Production @relation(fields: [productionId], references: [id], onDelete: Cascade)

  @@unique([productionId, personId, positionId])
  @@index([productionId])
  @@index([personId])
  @@index([positionId])
}

model ProductionSegment {
  id             Int                     @id @default(autoincrement())
  productionId   Int
  naam           String
  volgorde       Int
  duurInMinuten  Int
  isTimeAnchor   Boolean                 @default(false)
  callSheetItems CallSheetItem[]
  production     Production              @relation(fields: [productionId], references: [id], onDelete: Cascade)
  bezetting      SegmentRoleAssignment[]

  @@unique([productionId, volgorde])
  @@index([productionId])
}

model SegmentTemplate {
  id        Int                   @id @default(autoincrement())
  name      String                @unique
  isDefault Boolean               @default(false)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  items     SegmentTemplateItem[]
}

model SegmentTemplateItem {
  id            Int             @id @default(autoincrement())
  templateId    Int
  naam          String
  volgorde      Int
  duurInMinuten Int
  isTimeAnchor  Boolean         @default(false)
  template      SegmentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, volgorde])
  @@index([templateId])
}

model SegmentDefaultPosition {
  id          Int      @id @default(autoincrement())
  segmentName String
  positionId  Int
  order       Int
  position    Position @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@unique([segmentName, order])
  @@index([segmentName])
  @@index([positionId])
}

model SegmentRoleAssignment {
  id                  Int               @id @default(autoincrement())
  productionSegmentId Int
  personId            Int
  createdAt           DateTime          @default(now())
  positionId          Int
  person              Person            @relation(fields: [personId], references: [id], onDelete: Cascade)
  position            Position          @relation(fields: [positionId], references: [id], onDelete: Cascade)
  productionSegment   ProductionSegment @relation(fields: [productionSegmentId], references: [id], onDelete: Cascade)

  @@unique([productionSegmentId, positionId, personId])
  @@index([productionSegmentId])
  @@index([personId])
  @@index([positionId])
}

model Club {
  id        Int      @id @default(autoincrement())
  name      String
  shortName String
  slug      String   @unique
  logoUrl   String?
  createdAt DateTime @default(now())
  players   Player[]
}

model Player {
  id                Int                @id @default(autoincrement())
  clubId            Int
  name              String
  shirtNo           Int?
  gender            Gender?
  photoUrl          String?
  externalId        String?            @unique
  createdAt         DateTime           @default(now())
  function          String?
  personType        String?
  interviewSubjects InterviewSubject[]
  club              Club               @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@index([name])
}

model TitleDefinition {
  id                Int                @id @default(autoincrement())
  productionId      Int?
  name              String
  order             Int                @default(1)
  enabled           Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  interviewSubjects InterviewSubject[]
  production        Production?        @relation(fields: [productionId], references: [id], onDelete: Cascade)
  parts             TitlePart[]

  @@index([productionId, order])
}

model TitlePart {
  id                Int             @id @default(autoincrement())
  titleDefinitionId Int
  sourceType        TitleSourceType
  teamSide          TeamSide        @default(NONE)
  limit             Int?
  filters           Json?
  customFunction    String?
  customName        String?
  definition        TitleDefinition @relation(fields: [titleDefinitionId], references: [id], onDelete: Cascade)

  @@index([titleDefinitionId])
}

model InterviewSubject {
  id                Int              @id @default(autoincrement())
  productionId      Int
  side              TeamSide
  role              InterviewRole
  playerId          Int
  titleDefinitionId Int?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  player            Player           @relation(fields: [playerId], references: [id], onDelete: Cascade)
  production        Production       @relation(fields: [productionId], references: [id], onDelete: Cascade)
  titleDefinition   TitleDefinition? @relation(fields: [titleDefinitionId], references: [id])

  @@unique([productionId, side, role, titleDefinitionId])
  @@index([productionId])
  @@index([playerId])
  @@index([titleDefinitionId])
}

model PlayerImage {
  id        Int      @id @default(autoincrement())
  subject   String
  filename  String
  createdAt DateTime @default(now())

  @@index([subject])
}

model CallSheet {
  id           Int             @id @default(autoincrement())
  productionId Int
  name         String
  color        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  production   Production      @relation(fields: [productionId], references: [id], onDelete: Cascade)
  items        CallSheetItem[]

  @@unique([productionId, name])
  @@index([productionId])
}

model CallSheetItem {
  id                  String                  @id
  callSheetId         Int
  productionSegmentId Int
  cue                 String
  title               String
  note                String?
  color               String?
  timeStart           DateTime?
  timeEnd             DateTime?
  durationSec         Int
  orderIndex          Int                     @default(0)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  isInVenue           Boolean                 @default(false)
  anchorType          String?
  isTimeAnchor        Boolean                 @default(false)
  autoAdvance         Boolean                 @default(false)
  isInLivestream      Boolean                 @default(true)
  callSheet           CallSheet               @relation(fields: [callSheetId], references: [id], onDelete: Cascade)
  productionSegment   ProductionSegment       @relation(fields: [productionSegmentId], references: [id], onDelete: Cascade)
  positions           CallSheetItemPosition[]
  parentId            String?
  parent              CallSheetItem?          @relation("LinkedItems", fields: [parentId], references: [id], onDelete: SetNull)
  linkedItems         CallSheetItem[]         @relation("LinkedItems")

  @@index([callSheetId])
  @@index([productionSegmentId])
  @@index([parentId])
}

model CallSheetItemPosition {
  callSheetItemId String
  positionId      Int
  createdAt       DateTime      @default(now())
  item            CallSheetItem @relation(fields: [callSheetItemId], references: [id], onDelete: Cascade)
  position        Position      @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@id([callSheetItemId, positionId])
  @@index([positionId])
}

model Setting {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductionReport {
  id                 Int        @id @default(autoincrement())
  productionId       Int        @unique
  matchSponsor       String?
  interviewRationale String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  remarks            String?
  production         Production @relation(fields: [productionId], references: [id], onDelete: Cascade)

  @@index([productionId])
}

model ProductionEvent {
  id               String                    @id @default(cuid())
  productionId     Int
  metadata         Json?
  createdAt        DateTime                  @default(now())
  actualStartTime  DateTime?
  order            Int
  status           EventStatus               @default(WAITING)
  title            String
  triggerSource    TriggerSource             @default(MANUAL)
  vMixInputName    String?
  durationSec      Int?
  note             String?
  plannedEndTime   DateTime?
  plannedStartTime DateTime?
  anchorType       String?
  autoAdvance      Boolean                   @default(false)
  callSheetItemId  String?                   @unique
  parentId         String?
  parent           ProductionEvent?          @relation("LinkedEvents", fields: [parentId], references: [id], onDelete: SetNull)
  linkedItems      ProductionEvent[]         @relation("LinkedEvents")
  isInLivestream   Boolean                   @default(true)
  isInVenue        Boolean                   @default(false)
  isTimeAnchor     Boolean                   @default(false)
  production       Production                @relation(fields: [productionId], references: [id], onDelete: Cascade)
  positions        ProductionEventPosition[]

  @@index([productionId])
  @@index([productionId, createdAt])
  @@index([parentId])
}

model ProductionEventPosition {
  eventId    String
  positionId Int
  event      ProductionEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  position   Position        @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@id([eventId, positionId])
}

enum SponsorType {
  premium
  goud
  zilver
  brons
  event
}

enum Gender {
  male
  female
}

enum SkillType {
  crew
  entertainment
}

enum PositionCategory {
  GENERAL
  TECHNICAL
  ENTERTAINMENT
}

enum TitleSourceType {
  COMMENTARY
  PRESENTATION
  PRESENTATION_AND_ANALIST
  TEAM_PLAYER
  TEAM_COACH
  FREE_TEXT
}

enum TeamSide {
  HOME
  AWAY
  NONE
}

enum InterviewRole {
  PLAYER
  COACH
}

enum EventStatus {
  WAITING
  ACTIVE
  COMPLETED
}

enum TriggerSource {
  VMIX
  MANUAL
  AUTO
}
